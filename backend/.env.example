# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5500

# ─── Firebase ─────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id

# ─── AI Provider ──────────────────────────────────────────────────────────────
# Active providers: 'gemini' (default) | 'grok'
# System automatically fails over to grok if gemini quota is exhausted.
AI_PROVIDER=gemini

# ─── Gemini API Keys ──────────────────────────────────────────────────────────
# Get keys from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: comma-separated list for automatic key rotation on quota exhaustion
# GEMINI_API_KEYS=primary_key,backup_key_2,backup_key_3

# ─── Grok API Keys ────────────────────────────────────────────────────────────
# Get keys from: https://console.x.ai
GROK_API_KEY=your_grok_api_key_here

# Optional: comma-separated list for automatic key rotation
# GROK_API_KEYS=primary_key,backup_key_2
