# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5500

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
# You can connect using a single DATABASE_URL connection string (preferred for CockroachDB Cloud):
# DATABASE_URL=postgresql://your-user:your-password@your-cluster-xxxx.gcp-us-east1.cockroachlabs.cloud:26257/careeriqai?sslmode=verify-full
# Or connect using individual connection fields:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=careeriqai
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# ─── Firebase ─────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id

# ─── AI Provider ──────────────────────────────────────────────────────────────
# Active providers: 'gemini' (default) | 'grok'
# System automatically fails over to grok if gemini quota is exhausted.
AI_PROVIDER=gemini

# ─── Gemini API Keys ──────────────────────────────────────────────────────────
# Get keys from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: comma-separated list for automatic key rotation on quota exhaustion
# GEMINI_API_KEYS=primary_key,backup_key_2,backup_key_3

# ─── Grok API Keys ────────────────────────────────────────────────────────────
# Get keys from: https://console.x.ai
GROK_API_KEY=your_grok_api_key_here

# Optional: comma-separated list for automatic key rotation
# GROK_API_KEYS=primary_key,backup_key_2
